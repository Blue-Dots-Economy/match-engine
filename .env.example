# PostgreSQL Docker (for docker-compose.yaml)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=agent_interface
POSTGRES_PORT=5433

# Agent Interface DB (Application)
AGENT_DB_HOST=localhost
AGENT_DB_PORT=5433
AGENT_DB_NAME=agent_interface
AGENT_DB_USER=postgres
AGENT_DB_PASSWORD=postgres

# DPG Database (single URL)
# IMPORTANT: Ensure partitions exist for the items table before creating items
# See scripts/create-partitions.sql for partition setup
DPG_DATABASE_URL=postgresql://user:password@host:port/dbname

# App Settings
APP_HOST=0.0.0.0
APP_PORT=3001
NODE_ENV=development

# Auth Settings (optional)
# API_KEY_PREFIX=dpg_vai
# API_SECRET_PREFIX=dpg_vas
# API_KEY_EXPIRY_DAYS=