# PostgreSQL / Database Settings
# Note: for Docker, set POSTGRES_HOST=postgres (Docker service name)
POSTGRES_PORT=5433
POSTGRES_DB=agent_interface
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# DPG Database
DPG_DATABASE_URL=postgresql://user:password@host:port/dbname

# DPG Instance Settings
# The base URL where the DPG API actually runs (not this agent interface)
DPG_INSTANCE_URL=http://localhost:2742

# Schema Base URL - where to find network schema files
SCHEMA_BASE_URL=https://raw.githubusercontent.com/dhiway/dpg-monorepo/refs/heads/main/examples/schemas

# App Settings
APP_HOST=0.0.0.0
APP_PORT=3001
NODE_ENV=development

# Auth Settings (optional)
# API_KEY_PREFIX=dpg_vai
# API_SECRET_PREFIX=dpg_vas