# Agent Interface DB (Docker Compose)
AGENT_DB_HOST=localhost
AGENT_DB_PORT=5433
AGENT_DB_NAME=agent_interface
AGENT_DB_USER=postgres
AGENT_DB_PASSWORD=postgres

# DPG Database (single URL)
# Example: postgresql://postgres:password@host:port/dbname
DPG_DATABASE_URL=postgresql://postgres:da729670ee354c3er32b2ij3@127.0.0.1:5432/postgresdb

# App Settings
APP_HOST=0.0.0.0
APP_PORT=3001
NODE_ENV=development

# Auth Settings (optional)
# API_KEY_PREFIX=dpg_vai        # Prefix for API keys (default: dpg_vai)
# API_SECRET_PREFIX=dpg_vas     # Prefix for API secrets (default: dpg_vas)
# API_KEY_EXPIRY_DAYS=          # Optional: days until API key expires